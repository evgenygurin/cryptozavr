{
  "$schema": "https://anthropic.com/claude-code/mcp-schema.json",
  "mcpServers": {
    "cryptozavr-research": {
      "command": "sh",
      "args": [
        "-c",
        ". ${CLAUDE_PLUGIN_ROOT}/.env && uv run --directory ${CLAUDE_PLUGIN_ROOT} python -m cryptozavr.mcp.server"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
