# Cloud Supabase project
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api-keys
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role key from Dashboard → API Keys>

# PostgreSQL connection string (session pooler, port 5432 recommended for asyncpg)
# From Dashboard → Settings → Database → Connection string → Session pooler
SUPABASE_DB_URL=postgresql://postgres.<your-project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Plugin runtime
# CRYPTOZAVR_MODE: one of research_only | paper_trading | approval_gated_live | policy_constrained_auto_live
# MVP is locked to research_only. Other modes reserved for phase 2+.
CRYPTOZAVR_MODE=research_only

# CRYPTOZAVR_LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
CRYPTOZAVR_LOG_LEVEL=INFO
