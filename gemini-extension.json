{
  "name": "cryptozavr",
  "version": "0.1.0",
  "description": "Risk-first crypto market research for Gemini CLI.",
  "mcpServers": {
    "cryptozavr-research": {
      "command": "sh",
      "args": [
        "-c",
        ". ${CLAUDE_PLUGIN_ROOT}/.env && uv run --directory ${CLAUDE_PLUGIN_ROOT} python -m cryptozavr.mcp.server"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  },
  "contextFileName": "CLAUDE.md"
}
